# Django Security Settings
SECRET_KEY=django-insecure-change-me-to-a-secure-key

# Debug and Demo Mode
DEBUG=True # Enable debug mode for development
DEMO=False # Set to True for a disposable demo environment

# Connection Configuration
URL=http://127.0.0.1:8000
PORT=8000

# Database Configuration (sqlite or postgresql)
# NOTE: Set DATABASE_TYPE=sqlite and DEMO=True if you want a disposable demo container
DATABASE_TYPE=postgresql

# PostgreSQL settings
# These settings are used when DATABASE_TYPE is 'postgresql'
POSTGRES_DB=scholarships_db
POSTGRES_USER=scholarships_user
POSTGRES_PASSWORD=scholarships_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com
